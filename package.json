{
  "name": "orly",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright utilities for browser-side orly debugging.",
  "scripts": {
    "vendor:jscoq": "node scripts/vendor-jscoq.mjs",
    "playwright:install": "playwright install chromium",
    "test:q3dm1-browser": "npm run --silent vendor:jscoq && node scripts/repro-q3dm1-render.mjs",
    "test:pages-browser": "npm run --silent vendor:jscoq && ORLY_REPRO_SKIP_LOCAL=1 node scripts/repro-q3dm1-render.mjs",
    "repro:q3dm1-render": "npm run --silent vendor:jscoq && node scripts/repro-q3dm1-render.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "jscoq": "^0.17.1",
    "playwright": "^1.52.0"
  }
}
